---
// index.astro — thin composition root. Sections stack here in conversion order
// (ARCHITECTURE.md §4): hook → proof (TrustBar + Reviews) → desire → price → FAQ.
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import TrustBar from "../components/TrustBar.astro";
import Reviews from "../components/Reviews.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
import Audience from "../components/Audience.astro";
import EnrollNudge from "../components/EnrollNudge.astro";
// Outcomes intentionally dropped from the page (overlapped Curriculum/Projects,
// reduced text density). Component + outcomes.json kept dormant for easy re-add.
import Curriculum from "../components/Curriculum.astro";
import Projects from "../components/Projects.astro";
import ToolWall from "../components/ToolWall.astro";
import Credential from "../components/Credential.astro";
import Instructor from "../components/Instructor.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main>
    {/* Conversion order: proof up top (stats → logos → testimonials), price late. */}
    <Hero />
    <TrustBar />
    <LogoMarquee />
    <Reviews />
    <Curriculum />
    <EnrollNudge />
    <Projects />
    <ToolWall />
    <Credential />
    <Instructor />
    <Audience />
    <Pricing />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
