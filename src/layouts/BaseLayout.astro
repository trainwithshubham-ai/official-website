---
// BaseLayout — <head>, meta/OG, self-hosted fonts, analytics slots, UTM capture.
// Carries NO section markup; pages compose sections inside the <slot/>.
import { site } from "../config/site";
import StructuredData from "../components/StructuredData.astro";
import "../styles/tokens.css";

// Self-hosted fonts (BRAND.md §4) — only the weights AND subsets we use.
// latin-only subsets keep the shipped payload + critical CSS small (this is an
// English-audience page); unicode-range would gate downloads anyway, but this
// also stops the unused latin-ext/vietnamese faces from shipping at all.
import "@fontsource/space-grotesk/latin-500.css";
import "@fontsource/space-grotesk/latin-700.css";
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/jetbrains-mono/latin-500.css";
// Preload only the LCP face — the Space Grotesk 700 H1 — to cut the FOUT window.
import sg700 from "@fontsource/space-grotesk/files/space-grotesk-latin-700-normal.woff2?url";

interface Props {
  title?: string;
  description?: string;
  /** OG/Twitter image, relative to site root. */
  image?: string;
}

const {
  title = `${site.product} — ${site.brand}`,
  description = "DevOps: Zero to Hero — AI-powered live classes. From fundamentals to production: Docker, Kubernetes, Terraform, AWS, CI/CD, observability and Agentic AI.",
  image = "/og-image.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.domain).href;
const ogImage = new URL(image, site.domain).href;

// Analytics only render when real IDs are wired (placeholders start with "TODO").
const ga4Enabled = !site.ga4Id.startsWith("TODO");
const pixelEnabled = !site.metaPixelId.startsWith("TODO");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0A0E12" />

    <!-- favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- preload the LCP headline font (Space Grotesk 700) -->
    <link rel="preload" href={sg700} as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.brand} — ${site.product}`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${site.brand} — ${site.product}`} />

    <!-- SEO: Course / Organization / FAQ structured data (JSON-LD) -->
    <StructuredData description={description} />

    <!--
      Attribution without a backend (ARCHITECTURE.md §6):
      capture incoming utm_* params into sessionStorage so every Enroll CTA can
      forward them to checkout at click time. sessionStorage is the ONE allowed
      storage use (golden rule).
    -->
    <script is:inline>
      (function () {
        try {
          var qs = new URLSearchParams(window.location.search);
          var utm = {};
          qs.forEach(function (value, key) {
            if (key.indexOf("utm_") === 0) utm[key] = value;
          });
          if (Object.keys(utm).length) {
            sessionStorage.setItem("tws_utm", JSON.stringify(utm));
          }
        } catch (e) {
          /* storage blocked — attribution degrades silently */
        }
      })();
    </script>

    <script is:inline>
      /* Enroll-click attribution (ARCHITECTURE.md §6): every [data-enroll] CTA
         forwards stored utm_* params (+ src=site) to checkout at click time and
         fires one enroll_click event for GA4 / Meta Pixel funnel tracking. */
      document.addEventListener("click", function (e) {
        var t = e.target;
        var a = t && t.closest ? t.closest("[data-enroll]") : null;
        if (!a || a.tagName !== "A") return;
        try {
          var url = new URL(a.href, window.location.origin);
          var stored = sessionStorage.getItem("tws_utm");
          if (stored) {
            var utm = JSON.parse(stored);
            Object.keys(utm).forEach(function (k) {
              if (!url.searchParams.has(k)) url.searchParams.set(k, utm[k]);
            });
          }
          url.searchParams.set("src", "site");
          a.href = url.toString();
        } catch (err) {
          /* malformed/placeholder checkout URL — let the click proceed as-is */
        }
        var region = a.getAttribute("data-region") || undefined;
        if (typeof window.gtag === "function")
          window.gtag("event", "enroll_click", { region: region });
        if (typeof window.fbq === "function")
          window.fbq("track", "InitiateCheckout", { region: region });
      });
    </script>

    <script is:inline>
      /* Outbound wayfinding tracking: any [data-track] link (footer "All courses"
         / "Log in", the community #90DaysOfDevOps + YouTube links, future
         store/masterclass links) fires one outbound_click event, the data-track
         value as its label. Kept separate from enroll — no UTM forwarding and no
         checkout event; a login/catalog/community click is not an
         InitiateCheckout. No-ops safely until GA4 is wired (ga4Id still TODO). */
      document.addEventListener("click", function (e) {
        var t = e.target;
        var a = t && t.closest ? t.closest("[data-track]") : null;
        if (!a) return;
        var label = a.getAttribute("data-track") || undefined;
        if (typeof window.gtag === "function")
          window.gtag("event", "outbound_click", { label: label });
      });
    </script>

    <script is:inline>
      /* Region guess from the browser TIMEZONE (never IP) — Asia/Kolkata ⇒ India.
         Only emphasises the likely-correct Enroll button + personalises the
         geo-pricing note; both prices stay fully visible and are never switched.
         Sets data-region-guess on each [data-enroll-group]; CSS does the rest.
         Degrades silently — no JS ⇒ both buttons equal + neutral note. */
      (function () {
        function mark() {
          try {
            var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "";
            var guess = /Asia\/(Kolkata|Calcutta)/.test(tz) ? "india" : "world";
            var groups = document.querySelectorAll("[data-enroll-group]");
            for (var i = 0; i < groups.length; i++) {
              groups[i].setAttribute("data-region-guess", guess);
            }
          } catch (e) {
            /* no Intl / blocked — leave both buttons equal */
          }
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", mark);
        } else {
          mark();
        }
      })();
    </script>

    {
      ga4Enabled && (
        <Fragment>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${site.ga4Id}`}
          />
          <script is:inline define:vars={{ ga4Id: site.ga4Id }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", ga4Id);
          </script>
        </Fragment>
      )
    }

    {
      pixelEnabled && (
        <script is:inline define:vars={{ pixelId: site.metaPixelId }}>
          !(function (f, b, e, v, n, t, s) {
            if (f.fbq) return;
            n = f.fbq = function () {
              n.callMethod
                ? n.callMethod.apply(n, arguments)
                : n.queue.push(arguments);
            };
            if (!f._fbq) f._fbq = n;
            n.push = n;
            n.loaded = !0;
            n.version = "2.0";
            n.queue = [];
            t = b.createElement(e);
            t.async = !0;
            t.src = v;
            s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s);
          })(
            window,
            document,
            "script",
            "https://connect.facebook.net/en_US/fbevents.js",
          );
          fbq("init", pixelId);
          fbq("track", "PageView");
        </script>
      )
    }
  </head>
  <body>
    <!-- Skip link: first focusable element; hidden until focused, then jumps
         keyboard/SR users past the sticky nav to <main> (a11y). -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:border focus:border-primary focus:bg-surface focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-text focus:outline-none"
    >
      Skip to content
    </a>
    <!-- page grain (BRAND.md §3): behind content, can't affect contrast -->
    <div class="grain" aria-hidden="true"></div>
    <slot />
  </body>
</html>
