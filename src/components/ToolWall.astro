---
// ToolWall — the tools you'll actually use (ARCHITECTURE.md §4.8).
// Monochrome primary logo + name tiles (BRAND.md §6) — dev-native, no rainbow brand
// colors fighting the palette. Data: tools.json (all current entries have a
// vendored icon; one without an icon would simply show the name).
import Section from "./primitives/Section.astro";
import ToolIcon from "./primitives/ToolIcon.astro";
import { tools } from "../content/data";
---

<Section id="tools" eyebrow="tools" title="The tools you'll actually use">
  <ul
    class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"
    role="list"
  >
    {
      tools.map((t) => (
        <li class="surface-card flex items-center gap-2.5 rounded-[var(--radius-card)] border border-line bg-surface px-4 py-3">
          <ToolIcon name={t} class="text-[1.15rem] text-primary" />
          <span class="font-mono text-sm text-text">{t}</span>
        </li>
      ))
    }
  </ul>
</Section>
