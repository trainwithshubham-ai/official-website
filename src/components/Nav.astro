---
// Nav — sticky, quiet, conversion-forward. Logo + jump links + a compact
// Countdown chip + a ghost Log-in button (out to the Learnyst LMS) + the yellow
// Enroll CTA. JS-free: a persistent translucent backdrop reads as "floating"
// without a scroll listener (interactivity budget = the countdown only).
// Collapses gracefully to logo + Log in + Enroll at 380px.
import { site } from "../config/site";
import Button from "./primitives/Button.astro";
import Countdown from "./Countdown.astro";

const links = [
  { href: "#curriculum", label: "Curriculum" },
  { href: "#pricing", label: "Pricing" },
  { href: "#community", label: "Community" },
  { href: "#reviews", label: "Reviews" },
];
---

<header
  class="sticky top-0 z-50 border-b border-line/70 bg-ink/80 backdrop-blur-xl supports-[backdrop-filter]:bg-ink/65"
>
  <nav
    class="mx-auto flex h-20 max-w-[var(--container-content)] items-center gap-4 px-6"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="flex shrink-0 items-center gap-2.5"
      aria-label={`${site.brand} — home`}
    >
      <img
        src="/logo.png"
        alt={site.brand}
        width="56"
        height="56"
        class="size-14 rounded-md"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <span class="hidden font-display text-lg font-medium sm:inline"
        >{site.brand}</span
      >
    </a>

    <ul class="ml-2 hidden items-center gap-6 md:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-sm text-muted transition-colors hover:text-text"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="ml-auto flex items-center gap-3">
      <!-- wrap to hide on mobile: the Countdown's scoped display:inline-flex would
           otherwise override a `hidden` utility placed directly on it. -->
      <div class="hidden lg:block">
        <Countdown variant="chip" />
      </div>
      <Button
        variant="ghost"
        href={site.lms.signIn}
        class="px-4 py-2 text-sm"
        target="_blank"
        rel="noopener noreferrer"
        data-track="login"
        aria-label="Log in to your account on the student platform"
        >Log in</Button
      >
      <Button href="#pricing" class="px-4 py-2 text-sm">Enroll now</Button>
    </div>
  </nav>

  <!-- Mobile/tablet urgency: the desktop nav chip is hidden below lg, so phone
       users would feel no deadline until Pricing. This slim strip keeps the
       early-bird countdown persistent. The "ends in" label hides on expiry (the
       chip itself flips to "early-bird ended" via its cd-ended state) so the
       strip never contradicts itself. Reuses the shared Countdown island. -->
  <div
    class="nav-urgency flex items-center justify-center gap-2 border-t border-line/60 px-4 py-1.5 lg:hidden"
  >
    <span
      class="nav-urgency-lbl font-mono text-[0.7rem] lowercase tracking-[0.06em] text-muted"
    >
      ❯ early-bird ends in
    </span>
    <Countdown variant="chip" />
  </div>
</header>

<style>
  /* On expiry the chip flips to "early-bird ended · full price" itself, so drop
     the now-false "ends in" lead-in. */
  :global(html[data-early-bird-ended]) .nav-urgency-lbl {
    display: none;
  }
  /* In the slim mobile strip, drop the seconds unit: it keeps the label + chip
     within 380px and reads calmer (no per-second flicker in the nav). The
     full-precision countdowns in Pricing / Hero are untouched. */
  :global(.nav-urgency .cd-unit:last-child) {
    display: none;
  }
  /* Compact the chip so "early-bird ends in" + d/h/m fits at 380px. */
  :global(.nav-urgency .cd-units) {
    gap: 0.2rem;
  }
  :global(.nav-urgency .cd-num) {
    font-size: 0.8rem;
  }
  :global(.nav-urgency .cd-lbl) {
    font-size: 0.5rem;
  }
</style>
