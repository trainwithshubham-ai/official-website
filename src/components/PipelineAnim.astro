---
// PipelineAnim — the signature "deploying" motion (BRAND.md §2, the one bold
// motion moment). A compact code→production rail: nodes light up in sequence
// and a glowing pulse sweeps the track. CSS-only, zero JS.
// Decorative: marked role="img" with an accessible label; reduced-motion shows a
// static, fully-lit (finished) pipeline; labels hide below 400px.
const stages = ["code", "build", "test", "deploy", "production"];
---

<div
  class="pipe"
  role="img"
  aria-label="The curriculum runs like a deploy pipeline, from code to production"
>
  <ol class="track" aria-hidden="true">
    {
      stages.map((s, i) => (
        <li style={`--i:${i}`}>
          <span class:list={["node", i === stages.length - 1 && "node--prod"]} />
          <span class="lbl">{s}</span>
        </li>
      ))
    }
  </ol>
</div>

<style>
  .pipe {
    width: 100%;
    max-width: 30rem;
  }
  .track {
    position: relative;
    display: flex;
    justify-content: space-between;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  /* base rail + animated sweep sit behind the nodes */
  .track::before,
  .track::after {
    content: "";
    position: absolute;
    top: 5px;
    height: 2px;
    border-radius: 2px;
  }
  .track::before {
    left: 6px;
    right: 6px;
    background: var(--color-line);
  }
  .track::after {
    width: 52%;
    left: -52%;
    /* a comet: long soft tail trailing left → bright head at the leading edge */
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in srgb, var(--color-accent) 16%, transparent) 45%,
      color-mix(in srgb, var(--color-accent) 50%, transparent) 80%,
      var(--color-accent) 96%,
      transparent 100%
    );
    box-shadow: 0 0 9px color-mix(in srgb, var(--color-accent) 45%, transparent);
    filter: blur(0.2px);
    animation: pipe-sweep 1.9s linear infinite;
  }

  li {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .node {
    width: 12px;
    height: 12px;
    border-radius: 9999px;
    background: var(--color-surface-2);
    border: 2px solid var(--color-line);
    animation: pipe-light 1.9s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.28s);
  }

  .lbl {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  /* travels left → right, but swells in the middle of the run: thin + faint at
     the start and end, fullest as it crosses the centre of the rail. */
  @keyframes pipe-sweep {
    0% {
      left: -52%;
      opacity: 0;
      transform: scaleY(0.35);
    }
    22% {
      opacity: 1;
      transform: scaleY(1);
    }
    78% {
      opacity: 1;
      transform: scaleY(1);
    }
    100% {
      left: 100%;
      opacity: 0;
      transform: scaleY(0.35);
    }
  }
  /* seamless breathing wave — 0% and 100% match so the loop never snaps; each
     node swells to a glowing peak as the comet passes, then settles. */
  @keyframes pipe-light {
    0%,
    100% {
      background: var(--color-surface-2);
      border-color: var(--color-line);
      box-shadow: 0 0 0 0 transparent;
    }
    46%,
    64% {
      background: var(--color-primary);
      border-color: var(--color-primary);
      box-shadow:
        0 0 0 4px color-mix(in srgb, var(--color-primary) 16%, transparent),
        0 0 14px color-mix(in srgb, var(--color-primary) 55%, transparent);
    }
  }

  /* finished, static pipeline for reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .node {
      background: var(--color-primary);
      border-color: var(--color-primary);
      animation: none;
    }
    .track::after {
      display: none;
    }
  }

  /* simplify at 380px — keep the rail + nodes, drop the labels */
  @media (max-width: 400px) {
    .lbl {
      display: none;
    }
  }
</style>
