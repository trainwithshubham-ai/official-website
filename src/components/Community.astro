---
// Community — "you're not learning alone." Two honest lanes (golden rules 4 & 6):
//  • OPEN: the #90DaysOfDevOps open-source challenge — anyone can fork it. Real
//    GitHub metrics from site.ts (snapshots).
//  • STUDENT-ONLY: the Discord (invite is delivered on enrollment — there is no
//    public join link) + the ebook bonus. So its CTA is Enroll, not a link.
// All data from site.ts. Icons inline (no icon pack, per Do-NOT rules).
import Section from "./primitives/Section.astro";
import Button from "./primitives/Button.astro";
import { site } from "../config/site";

const { challenge, discord } = site.community;
---

<Section
  id="community"
  eyebrow="community"
  title="You won't be doing this alone"
>
  <div class="grid gap-6 md:grid-cols-2">
    <!-- OPEN TO EVERYONE — #90DaysOfDevOps -->
    <article
      class="surface-card flex flex-col rounded-[var(--radius-card)] border border-line bg-surface p-6 sm:p-8"
    >
      <div class="mb-4 flex items-center gap-3">
        <svg
          class="size-6 shrink-0 text-text"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        <h3 class="text-text">{challenge.name}</h3>
        <span
          class="ml-auto rounded-full border border-line px-2.5 py-0.5 font-mono text-[0.65rem] uppercase tracking-[0.08em] text-muted"
          >open to all</span
        >
      </div>
      <p class="text-pretty text-muted">
        The free, open-source challenge that started the movement. Fork the
        roadmap, learn in public, and build the habit — no enrollment needed.
      </p>

      <dl class="my-7 flex gap-10 font-mono">
        <div class="flex flex-col gap-1">
          <dt class="text-xs uppercase tracking-[0.08em] text-muted">Forks</dt>
          <dd class="text-2xl font-medium text-primary">{challenge.forks}</dd>
        </div>
        <div class="flex flex-col gap-1">
          <dt class="text-xs uppercase tracking-[0.08em] text-muted">Stars</dt>
          <dd class="text-2xl font-medium text-primary">{challenge.stars}</dd>
        </div>
      </dl>

      <div class="mt-auto flex flex-wrap items-center gap-x-6 gap-y-3">
        <Button
          href={challenge.repo}
          variant="ghost"
          class="px-4 py-2 text-sm"
          target="_blank"
          rel="noopener noreferrer"
          data-track="90days-github"
          aria-label="Star it on GitHub — #90DaysOfDevOps (opens in new tab)"
        >
          Star it on GitHub
        </Button>
        <a
          href={site.social.youtube.url}
          target="_blank"
          rel="noopener noreferrer"
          data-track="youtube-free"
          class="text-sm text-muted underline-offset-4 transition-colors hover:text-text hover:underline"
          aria-label="Free on YouTube (opens in new tab)"
        >
          Free on YouTube →
        </a>
      </div>
    </article>

    <!-- STUDENT-ONLY — Discord + ebook, unlocked on enrollment -->
    <article
      class="surface-card flex flex-col rounded-[var(--radius-card)] border border-line bg-surface p-6 sm:p-8"
    >
      <div class="mb-4 flex items-center gap-3">
        <svg
          class="size-6 shrink-0 text-primary"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M20.317 4.369a19.79 19.79 0 00-4.885-1.515.074.074 0 00-.079.037c-.211.375-.444.865-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.369a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.291.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.009c.12.099.246.198.373.292a.077.077 0 01-.006.127 12.3 12.3 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.094 2.157 2.418 0 1.334-.956 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.418 2.157-2.418 1.21 0 2.176 1.094 2.157 2.418 0 1.334-.946 2.419-2.157 2.419z"
          ></path>
        </svg>
        <h3 class="text-text">When you enroll</h3>
        <span
          class="ml-auto rounded-full border border-primary/40 px-2.5 py-0.5 font-mono text-[0.65rem] uppercase tracking-[0.08em] text-primary"
          >students only</span
        >
      </div>
      <p class="text-pretty text-muted">
        Enrolling puts you inside our private Discord — <span class="text-text"
          >{discord.members} learners</span
        > already in. The invite comes with your enrollment.
      </p>

      <ul class="my-7 flex flex-col gap-3" role="list">
        {
          discord.perks.map((perk) => (
            <li class="flex items-start gap-3">
              <span
                class="mt-2 size-1.5 shrink-0 rounded-full bg-primary"
                aria-hidden="true"
              />
              <span class="text-text">{perk}</span>
            </li>
          ))
        }
        {
          site.bonus.enabled && (
            <li class="flex items-start gap-3">
              <span
                class="mt-2 size-1.5 shrink-0 rounded-full bg-primary"
                aria-hidden="true"
              />
              <span class="text-text">
                {site.bonus.name} — yours free on enrollment
              </span>
            </li>
          )
        }
      </ul>

      <div class="mt-auto">
        <Button href="#pricing" class="px-4 py-2 text-sm">Enroll now</Button>
      </div>
    </article>
  </div>
</Section>
