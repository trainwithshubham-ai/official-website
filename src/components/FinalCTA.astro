---
// FinalCTA — the closing band (ARCHITECTURE.md §4.13). Reuses the Countdown
// (the deploy window) + the Enroll CTA. One last, calm, confident push.
import { site } from "../config/site";
import Countdown from "./Countdown.astro";
import EnrollButtons from "./EnrollButtons.astro";
---

<section id="enroll" aria-labelledby="enroll-heading" class="reveal border-t border-line">
  <div
    class="mx-auto flex max-w-[var(--container-content)] flex-col items-center gap-7 px-6 py-[clamp(4rem,9vw,7rem)] text-center"
  >
    <p
      class="font-mono text-[length:var(--text-eyebrow)] lowercase tracking-[0.08em] text-signal"
    >
      ❯ deploy your enrollment
    </p>
    <h2 id="enroll-heading" class="max-w-2xl text-balance">
      Ready to go from zero to hero?
    </h2>
    <p class="max-w-xl text-pretty text-muted">
      Join the cohort, build real systems, and ship to production with AI in your
      workflow. {site.tagline}
    </p>

    <Countdown variant="full" class="items-center" />

    <EnrollButtons />
  </div>
</section>
