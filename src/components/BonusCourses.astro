---
// BonusCourses — the flagship's "enrol and get courses free" strip. Renders the
// courses flagged `bonus: true` (flagshipBonuses, courses.ts) via the shared
// CourseCard, with the real standalone value ("normally ₹4,999, yours free"). Lives
// on the homepage near Pricing. --cta yellow stays reserved for Enroll/Pay; the
// "Included free" tag + CTA use the accent. Availability is shown per-card (coming
// soon), so the copy doesn't claim every course is available the instant you join.
import Section from "./primitives/Section.astro";
import CourseCard from "./primitives/CourseCard.astro";
import { flagshipBonuses } from "../config/courses";

const n = flagshipBonuses.length;
---

{
  n > 0 && (
    <Section
      eyebrow="free bonuses"
      title={`Enrol and get ${n} ${n === 1 ? "course" : "courses"}, free`}
    >
      <p class="mb-10 max-w-2xl text-pretty text-muted">
        Every DevOps: Zero to Hero enrolment includes these standalone courses at no
        extra cost — yours as part of the flagship.
      </p>

      <ul class="grid gap-5 sm:grid-cols-2" role="list">
        {flagshipBonuses.map((b) => (
          <li>
            <CourseCard
              href={b.href}
              poster={b.poster}
              title={b.title}
              as="h3"
              theme={b.theme}
              ctaLabel={b.comingSoon ? "Preview" : "See what's inside"}
            >
              <span
                slot="tags"
                class="rounded-[var(--radius-pill)] border border-line px-2.5 py-0.5 font-mono text-[0.62rem] uppercase tracking-[0.08em] text-primary"
              >
                Included free{b.comingSoon ? " · coming soon" : ""}
              </span>
              <p class="text-sm text-muted">
                {b.value ? (
                  <>
                    Normally <s>{b.value}</s> — yours free
                  </>
                ) : (
                  "Free with your enrolment"
                )}
              </p>
            </CourseCard>
          </li>
        ))}
      </ul>
    </Section>
  )
}
