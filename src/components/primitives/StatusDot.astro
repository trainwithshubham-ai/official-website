---
// StatusDot — 8px observability-style status dot (BRAND.md §6).
// primary = healthy/real/done (default), signal = urgency, cta = action.
// Decorative by default; pass `label` to expose meaning to assistive tech.
interface Props {
  tone?: "primary" | "signal" | "cta" | "muted";
  label?: string;
  class?: string;
}
const { tone = "primary", label, class: className = "" } = Astro.props;
const toneVar = {
  primary: "var(--color-primary)",
  signal: "var(--color-signal)",
  cta: "var(--color-cta)",
  muted: "var(--color-muted)",
}[tone];
---

<span
  class:list={["inline-block size-2 shrink-0 rounded-full", className]}
  style={`background-color:${toneVar}`}
  role={label ? "img" : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : "true"}
>
</span>
