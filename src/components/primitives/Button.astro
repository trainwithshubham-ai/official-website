---
// Button — the only two button styles (BRAND.md §6).
//   primary = yellow CTA fill, ink text  → THE Enroll CTA (the CTA color is sacred, §3)
//   ghost   = transparent, purple border/text → secondary ("See the curriculum")
// Renders <a> when `href` is set, else <button>. Labels are verbs, never "Submit".
//
// `enroll`: marks this as an Enroll CTA → adds data-enroll so the global handler
// in BaseLayout forwards UTM params to checkout and fires `enroll_click` (§6).
interface Props {
  variant?: "primary" | "ghost";
  href?: string;
  enroll?: boolean;
  type?: "button" | "submit";
  class?: string;
  [key: string]: unknown;
}
const {
  variant = "primary",
  href,
  enroll = false,
  type = "button",
  class: className = "",
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-[var(--radius-btn)] px-5 py-3 font-medium leading-none transition-[transform,background-color,border-color] duration-150 motion-safe:hover:-translate-y-px focus-visible:outline-2 focus-visible:outline-offset-2";

const variants = {
  // yellow CTA fill, ink text, lift + cta-deep on hover
  primary:
    "bg-cta text-ink hover:bg-cta-deep focus-visible:outline-cta",
  // transparent, purple 1px border, purple text
  ghost:
    "border border-primary text-primary hover:bg-primary/10 focus-visible:outline-primary",
};

const Tag = href ? "a" : "button";
const isExternal = !!href && /^https?:\/\//.test(href);
const enrollAttrs = enroll ? { "data-enroll": "" } : {};
// Enroll checkouts are region-locked on Learnyst; open them in a new tab so a
// wrong-region click never destroys the sales page (the errored tab is
// disposable — the learner just returns and picks the other region).
const newTabAttrs =
  enroll && isExternal
    ? { target: "_blank", rel: "noopener noreferrer" }
    : isExternal
      ? { rel: "noopener" }
      : {};
const tagAttrs = href
  ? { href, ...newTabAttrs, ...enrollAttrs }
  : { type, ...enrollAttrs };
---

<Tag class:list={[base, variants[variant], className]} {...tagAttrs} {...rest}>
  <slot />
</Tag>
