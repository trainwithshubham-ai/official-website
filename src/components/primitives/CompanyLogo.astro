// Infosys & OpenText are intentionally NOT here — their detailed wordmark-logos
// are illegible at marquee size, so they fall back to clean text wordmarks.

const key = name.toLowerCase().replace(/[^a-z0-9]/g, "");
const d = LOGOS[key];
// Most Simple Icons fill the full 24×24 box; the AWS wordmark is wide + short
// (glyph spans y≈4.6–19), so give it a tighter viewBox to fill the logo height
// and sit optically level with the square logos next to it.
const viewBox = key === "aws" ? "0 4 24 16" : "0 0 24 24";
---

{
  d ? (
    <svg
      class:list={["co-logo", className]}
      viewBox={viewBox}
      width="30"
      height="30"
      fill="currentColor"
      role="img"
      aria-label={name}
    >
      <path d={d} />
    </svg>
  ) : (
    <span class:list={["co-word", className]}>{name}</span>
  )
}

<style>
  /* symbol logos run a touch larger than the wordmarks so the two optically
     balance in the same row */
  .co-logo {
    height: 1.85rem;
    width: auto;
    display: block;
  }
  .co-word {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.2rem;
    line-height: 1;
    white-space: nowrap;
  }
</style>
