---
// Globe — monochrome line globe (currentColor), aria-hidden. Region marker for
// "rest of world / global".
interface Props {
  size?: number;
  class?: string;
}
const { size = 18, class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  aria-hidden="true"
  class:list={["shrink-0", className]}
>
  <circle cx="12" cy="12" r="9"></circle>
  <path d="M3 12h18M12 3c2.6 2.7 2.6 15.3 0 18M12 3c-2.6 2.7-2.6 15.3 0 18"></path>
</svg>
