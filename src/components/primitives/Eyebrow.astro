---
// Eyebrow — the mono terminal-prompt section label (BRAND.md §2, §4).
// e.g. ❯ curriculum. Lowercase, monospace, muted.
interface Props {
  text: string;
  as?: "p" | "span" | "div";
  class?: string;
}
const { text, as: Tag = "p", class: className = "" } = Astro.props;
---

<Tag
  class:list={[
    "font-mono text-[length:var(--text-eyebrow)] lowercase tracking-[0.08em] text-muted",
    className,
  ]}
>
  <span aria-hidden="true" class="text-primary">❯</span>{" "}{text}
</Tag>
