---
// EnrollNudge — a slim payoff CTA right after the Curriculum. The pipeline flows
// code → production as you scroll; this caps it with a gentle pulsing "Enroll
// now" that jumps to the pricing box. Pulse is reduced-motion-safe (tokens.css).
import Button from "./primitives/Button.astro";
---

<section class="reveal py-12">
  <div
    class="mx-auto flex max-w-[var(--container-content)] flex-col items-center gap-4 px-6 text-center"
  >
    <p
      class="font-mono text-[length:var(--text-eyebrow)] lowercase tracking-[0.08em] text-muted"
    >
      <span aria-hidden="true" class="text-primary">❯</span> like the roadmap?
    </p>
    <Button href="#pricing" class="pulse-cta">Enroll now</Button>
  </div>
</section>
