---
// Instructor — Shubham, with the human "Hello Dosto" note (BRAND.md §7,
// ARCHITECTURE.md §4.9). Real proof from site.ts; bio kept honest and general.
import Section from "./primitives/Section.astro";
import { site } from "../config/site";

const socials = [
  { ...site.social.youtube, name: "YouTube" },
  { ...site.social.linkedin, name: "LinkedIn" },
  { ...site.social.instagram, name: "Instagram" },
];

// What Shubham teaches — a small, honest focus-areas row for the card.
const focusAreas = ["DevOps", "Cloud", "Python", "Agentic AI"];
---

<Section id="instructor" eyebrow="instructor" title="Hello Dosto">
  <div class="grid gap-8 md:grid-cols-[1.4fr_1fr] md:items-start">
    <!-- bio -->
    <div class="flex flex-col gap-4 text-pretty text-muted">
      <p>
        I'm Shubham. For 9+ years I've built and run real software in production,
        and today I work as a <span class="text-text">Developer Advocate at
        Temporal</span> while teaching DevOps, Cloud and AI to engineers everywhere.
      </p>
      <p>
        I started <span class="text-text">TrainWithShubham</span> with one goal — to
        help you start and grow your IT career, whatever your background. More than{" "}
        <span class="text-text">{site.studentsTrained}</span> engineers have learned
        with us through live cohorts, hands-on courses, and a community that shows up
        every day. Many have gone on to jobs at top companies.
      </p>
      <p>
        The way I teach is simple: real tools, real systems, and no boring slides.
        You learn by building, with AI in your workflow all the way through. Come in
        curious and ready to build. {site.tagline}
      </p>
    </div>

    <!-- card -->
    <aside
      class="surface-card rounded-[var(--radius-card)] border border-line bg-surface p-6"
    >
      <picture>
        <source srcset="/instructor-shubham.webp" type="image/webp" />
        <img
          src="/instructor-shubham.jpg"
          alt="Shubham, founder of TrainWithShubham"
          width="600"
          height="600"
          class="aspect-square w-full rounded-[var(--radius-card)] object-cover ring-1 ring-line"
          loading="lazy"
          decoding="async"
        />
      </picture>
      <div class="mt-4">
        <p class="font-display font-medium text-text">Shubham Londhe</p>
        <p class="text-sm text-muted">Founder, {site.brand}</p>
        <p class="text-sm text-muted">Developer Advocate at Temporal</p>
      </div>

      {/* Instructor/brand stats only — NOT a course rating. The 4.9★ Google rating
          lives in TrustBar + Reviews (its proper, sourced context); repeating it here
          would misread as a per-course rating on the standalone course pages. */}
      <dl class="mt-6 grid grid-cols-2 gap-4">
        <div>
          <dt class="text-xs text-muted">Trained</dt>
          <dd class="font-display text-xl font-medium text-text">
            {site.studentsTrained}
          </dd>
        </div>
        <div>
          <dt class="text-xs text-muted">In production</dt>
          <dd class="font-display text-xl font-medium text-text">9+ yrs</dd>
        </div>
      </dl>

      <!-- focus areas — fills the card, on-brand mono pills -->
      <div class="mt-6 border-t border-line pt-5">
        <p class="text-xs text-muted">Teaches</p>
        <ul class="mt-2 flex flex-wrap gap-2" role="list">
          {
            focusAreas.map((f) => (
              <li class="rounded-[var(--radius-pill)] border border-line px-2.5 py-0.5 font-mono text-[0.7rem] text-muted">
                {f}
              </li>
            ))
          }
        </ul>
      </div>

      <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-sm" role="list">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.name} (opens in new tab)`}
                class="text-primary transition-colors hover:underline"
              >
                {s.name}
              </a>
            </li>
          ))
        }
      </ul>
    </aside>
  </div>
</Section>
