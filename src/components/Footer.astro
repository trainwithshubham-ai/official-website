---
// Footer — legal, socials, contact, and the human disclaimer (ARCHITECTURE.md
// §4.14). All values from site.ts.
import { site } from "../config/site";
import FlagIndia from "./primitives/FlagIndia.astro";
import Globe from "./primitives/Globe.astro";

const year = new Date().getFullYear();

const jumpLinks = [
  { href: "#curriculum", label: "Curriculum" },
  { href: "#projects", label: "Projects" },
  { href: "#pricing", label: "Pricing" },
  { href: "#community", label: "Community" },
  { href: "#reviews", label: "Reviews" },
  { href: "#faq", label: "FAQ" },
];

const socials = [
  { ...site.social.youtube, name: "YouTube" },
  { ...site.social.linkedin, name: "LinkedIn" },
  { ...site.social.instagram, name: "Instagram" },
];

// Outbound wayfinding to the LMS (Learnyst) on courses.trainwithshubham.ai. Add
// future destinations (store, free masterclasses, ebooks) here — one line each.
const lmsLinks = [
  { href: site.lms.explore, label: "All courses", track: "all-courses" },
  { href: site.lms.signIn, label: "Log in", track: "login" },
];
---

<footer class="border-t border-line">
  <div
    class="mx-auto grid max-w-[var(--container-content)] gap-10 px-6 py-14 sm:grid-cols-2 md:grid-cols-[1.6fr_1fr_1fr_1fr]"
  >
    <!-- brand -->
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2.5">
        <img
          src="/logo.png"
          alt={site.brand}
          width="32"
          height="32"
          class="size-8 rounded-md"
          loading="lazy"
          decoding="async"
        />
        <span class="font-display font-medium text-text">{site.brand}</span>
      </div>
      <p class="max-w-xs text-pretty text-sm text-muted">{site.tagline}</p>
      <a
        href={`mailto:${site.contactEmail}`}
        class="text-sm text-primary transition-colors hover:underline"
      >
        {site.contactEmail}
      </a>
    </div>

    <!-- explore -->
    <nav aria-label="Footer" class="flex flex-col gap-3">
      <p class="font-mono text-xs uppercase tracking-[0.08em] text-muted">
        Explore
      </p>
      <ul class="flex flex-col gap-2" role="list">
        {
          jumpLinks.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-sm text-muted transition-colors hover:text-text"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- learn (LMS wayfinding) -->
    <nav aria-label="Learn" class="flex flex-col gap-3">
      <p class="font-mono text-xs uppercase tracking-[0.08em] text-muted">
        Learn
      </p>
      <ul class="flex flex-col gap-2" role="list">
        {
          lmsLinks.map((l) => (
            <li>
              <a
                href={l.href}
                data-track={l.track}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${l.label} (opens in new tab)`}
                class="text-sm text-muted transition-colors hover:text-text"
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- social -->
    <div class="flex flex-col gap-3">
      <p class="font-mono text-xs uppercase tracking-[0.08em] text-muted">
        Follow
      </p>
      <ul class="flex flex-col gap-2" role="list">
        {
          socials.map((s) => (
            <li>
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.name} (opens in new tab)`}
                class="text-sm text-muted transition-colors hover:text-text"
              >
                {s.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <div
      class="mx-auto flex max-w-[var(--container-content)] flex-col gap-2 px-6 py-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.brand}. All rights reserved.</p>
      <p class="inline-flex items-center gap-1.5">
        Made in India <FlagIndia width={18} height={12} /> for the world
        <Globe size={15} />
      </p>
    </div>
  </div>
</footer>
