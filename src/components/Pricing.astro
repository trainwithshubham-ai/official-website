---
// Pricing — the conversion core (ARCHITECTURE.md §4.10).
// Transparent dual pricing (India / US, no IP geo-switch — golden rule 6), a
// "batch starts in" Countdown, inclusions, and the Enroll CTA. One standing price:
// `now` beside a struck `list` original — a discount, NOT an early-bird window
// (no expiry, no price flip; golden rule 6 — honesty over fake urgency).
import { site } from "../config/site";
import Section from "./primitives/Section.astro";
import Countdown from "./Countdown.astro";
import EnrollButtons from "./EnrollButtons.astro";
import BonusBar from "./BonusBar.astro";
import { inclusions } from "../content/data";

const refundReady = !site.refundPolicy.startsWith("TODO");

// Screen-reader price breakdown — built as a string so Astro's whitespace trimming
// around {expressions} can't drop spaces between price + currency.
const priceSr = `Price: ${site.price.india.now} for India (originally ${site.price.india.list}), ${site.price.world.now} for the rest of the world (originally ${site.price.world.list}). Choose your region to pay.`;
---

<Section id="pricing" eyebrow="pricing" title="Enrol now — secure your seat">
  <div
    class="pricing-card surface-card grad-border mx-auto w-full max-w-xl rounded-[var(--radius-card)] p-8 text-center sm:p-10"
  >
    <p
      class="font-mono text-[length:var(--text-eyebrow)] lowercase tracking-[0.08em] text-primary"
    >
      ❯ your price
    </p>
    <!-- Region-priced: the visitor's likely currency (browser timezone, never
         IP — flag set pre-paint on <html>) is the big anchor; the other stays
         visible but smaller. Both always shown — emphasis, never a hide/swap
         (golden rule 6). India is the default anchor when region is unknown. -->
    <div aria-hidden="true">
      <div
        class="mt-3 flex flex-wrap items-baseline justify-center gap-x-2 gap-y-1"
      >
        <span class="text-lg text-muted">from</span>
        <span class="price-amt amt-india">{site.price.india.now}</span>
        <span class="price-sep">·</span>
        <span class="price-amt amt-world">{site.price.world.now}</span>
      </div>
      <p class="mt-2 text-sm text-muted">
        originally <s>{site.price.india.list}</s> /
        <s>{site.price.world.list}</s>
      </p>
    </div>
    <p class="sr-only">{priceSr}</p>

    <div class="mt-6 flex justify-center">
      <Countdown variant="full" class="items-center" />
    </div>

    <!-- inclusions -->
    <!-- list block is centered (mx-auto w-fit) for box symmetry, but items stay
         left-aligned so the checkmarks form a clean column -->
    <ul class="mx-auto mt-8 flex w-fit flex-col gap-3 text-left">
      {
        inclusions.map((item) => (
          <li class="flex items-start gap-3">
            <svg
              class="mt-0.5 size-5 shrink-0 text-primary"
              viewBox="0 0 20 20"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M4 10.5l3.5 3.5L16 6"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span class="text-text">{item}</span>
          </li>
        ))
      }
    </ul>

    <!-- daily bonus (real, repeatable; honest end-of-day IST timer) -->
    <BonusBar class="mt-8" />

    <!-- CTA — one button per region (transparent, learner picks; golden rule 6).
         `note` shows the welcoming geo-pricing helper here (the main conversion
         point); FinalCTA reuses the buttons without it. -->
    <EnrollButtons class="mt-5" note />

    {
      refundReady && (
        <p class="mt-4 text-center text-sm text-muted">{site.refundPolicy}</p>
      )
    }
  </div>
</Section>

<style>
  /* Region-priced headline: the detected region's amount (html[data-region-guess],
     set pre-paint in BaseLayout — timezone, never IP) is the big anchor; the other
     stays visible but smaller. Emphasis only — both always shown (golden rule 6).
     India is the default anchor when the region is unknown (attr unset). Because
     the flag is set before first paint, there's no ₹→$ flip/flash on load. */
  .price-amt {
    font-family: var(--font-display);
    line-height: 1.1;
  }
  /* ANCHOR (big) — the visitor's OWN currency: India by default, the world price
     when the region flag flips. Defined once, applied to whichever span is the
     anchor. (The html[...] selector outspecifies the base, so on a world visitor
     .amt-world wins the anchor and .amt-india falls to ALT below.) */
  .amt-india,
  :global(html[data-region-guess="world"]) .amt-world {
    font-size: clamp(2rem, 9vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
  }
  /* ALT (small) — the other currency, kept fully visible but secondary. */
  .amt-world,
  :global(html[data-region-guess="world"]) .amt-india {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-muted);
  }
  .price-sep {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-muted);
  }
</style>
