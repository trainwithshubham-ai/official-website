---
// Reviews — REAL, consented learner testimonials from reviews.json (validated by
// the content collection). Each card shows a real photo + role/company + the
// student's own words (a trimmed excerpt). A standalone badge links to the real
// 4.9★/232 Google rating. Never fabricate or misquote (golden rule 4, BRAND.md
// §6). Google reviews (with a `url`) and student testimonials can coexist here.
import { getCollection } from "astro:content";
import Section from "./primitives/Section.astro";
import { site } from "../config/site";

const reviews = (await getCollection("reviews")).map((e) => e.data);

const readAllHref = site.googleProfileUrl.startsWith("TODO")
  ? site.googleReviewUrl
  : site.googleProfileUrl;

// Trim to a clean excerpt at a word boundary; the full text lives on Google.
function excerpt(text: string, max = 180) {
  if (text.length <= max) return text;
  const cut = text.slice(0, max);
  const i = cut.lastIndexOf(" ");
  return (i > 0 ? cut.slice(0, i) : cut).trimEnd() + "…";
}

// Honest avatar: a real photo when provided, else a monogram from the real
// reviewer's initial (never a fabricated face — golden rule 4).
const initial = (name: string) => name.trim().charAt(0).toUpperCase();
// Build the "role · company · location" subline from whatever real fields exist.
const subline = (r: { role?: string; company?: string; location?: string }) =>
  [[r.role, r.company].filter(Boolean).join(", "), r.location]
    .filter(Boolean)
    .join(" · ");
---

<Section id="reviews" eyebrow="reviews" title="What learners say">
  <!-- Standalone Google rating stat that links out — kept separate from the
       student-testimonial cards below so it doesn't imply those are Google reviews. -->
  <a
    href={readAllHref}
    target="_blank"
    rel="noopener noreferrer"
    class="group mb-10 inline-flex items-center gap-3 rounded-[var(--radius-pill)] border border-line bg-surface px-4 py-2"
  >
    <span class="font-display text-lg font-medium text-text"
      >{site.googleRating}</span
    >
    <span class="text-signal" aria-hidden="true">★</span>
    <span class="text-sm text-muted group-hover:text-text">
      · {site.googleReviewCount} reviews on Google <span aria-hidden="true">→</span>
    </span>
    <span class="sr-only">(opens in new tab)</span>
  </a>

  <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" role="list">
    {
      reviews.map((r, i) => (
        <li class="surface-card lift flex flex-col rounded-[var(--radius-card)] border border-line border-l-2 border-l-teal bg-surface p-6 hover:border-l-teal/80">
          <div class="flex items-center gap-3">
            {r.photo ? (
              <img
                src={r.photo}
                alt=""
                width="44"
                height="44"
                class="size-11 shrink-0 rounded-full object-cover"
                loading={i < 3 ? "eager" : "lazy"}
                decoding="async"
              />
            ) : (
              <span
                aria-hidden="true"
                class="grid size-11 shrink-0 place-items-center rounded-full bg-gradient-to-br from-teal to-teal-deep font-display text-lg font-medium text-ink"
              >
                {initial(r.name)}
              </span>
            )}
            <div class="min-w-0">
              <p class="truncate font-medium text-text">
                {r.name}
                {r.localGuide && (
                  <span class="ml-1.5 align-middle font-mono text-[0.6rem] text-muted">
                    Local Guide
                  </span>
                )}
              </p>
              <p class="truncate text-xs text-muted">
                {subline(r) || r.dateLabel}
              </p>
            </div>
          </div>

          <span
            class="mt-4 text-signal"
            role="img"
            aria-label={`Rated ${r.rating} out of 5`}
          >
            <span aria-hidden="true">{"★".repeat(r.rating)}</span>
          </span>

          <p class="mt-3 grow text-pretty text-sm text-muted">
            {excerpt(r.text)}
          </p>

          {r.outcome && (
            <p class="mt-3 border-l-2 border-l-teal/50 pl-3 text-sm text-text">
              {r.outcome}
            </p>
          )}

          {
            r.url && (
              <a
                href={r.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 text-sm text-teal transition-colors hover:underline"
              >
                Read on Google <span aria-hidden="true">→</span>
                <span class="sr-only">
                  — full review by {r.name} (opens in new tab)
                </span>
              </a>
            )
          }
        </li>
      ))
    }
  </ul>
</Section>
