---
// BonusBar — a slim "your enrolment includes free courses" callout for the Pricing
// box. Driven by flagshipBonuses (courses.ts, single source), so it names the real
// bundled courses and stays in sync as bonuses are added. Deliberately NOT a timer —
// the Pricing card already carries the batch-start Countdown. Renders only when there
// is at least one bonus course.
import { flagshipBonuses } from "../config/courses";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;

const names = flagshipBonuses.map((b) => b.title).join(" + ");
const n = flagshipBonuses.length;
---

{
  n > 0 && (
    <div class:list={["bonus-bar grad-border", className]} role="note">
      <p class="bonus-copy">
        <span class="bonus-ic" aria-hidden="true">
          🎁
        </span>
        <span>
          Your enrolment includes <strong>{n} courses free</strong> —{" "}
          <strong class="bonus-name">{names}</strong>.
        </span>
      </p>
    </div>
  )
}

<style>
  .bonus-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 1rem;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-pill);
    text-align: center;
  }
  .bonus-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .bonus-ic {
    font-size: 1.05rem;
    line-height: 1;
  }
  .bonus-name {
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
