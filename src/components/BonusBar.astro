---
// BonusBar — a slim, honest "enroll today" bonus callout for the Pricing box.
// The bonus is REAL and repeatable (enroll before tonight's midnight IST and get
// the ebook — golden rule 6). It is deliberately NOT a ticking clock: the Pricing
// card already carries the early-bird Countdown, so a second timer here would be
// two competing clocks in one decision zone. This stays a calm gift callout; the
// "today" framing keeps the honest end-of-day deadline without the visual race.
// Renders only when site.bonus.enabled.
import { site } from "../config/site";

interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{
  site.bonus.enabled && (
    <div class:list={["bonus-bar grad-border", className]} role="note">
      <p class="bonus-copy">
        <span class="bonus-ic" aria-hidden="true">
          🎁
        </span>
        <span>
          Enroll <strong>today</strong> and get the{" "}
          <strong class="bonus-name">{site.bonus.name}</strong> — free.
        </span>
      </p>
    </div>
  )
}

<style>
  .bonus-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 1rem;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-pill);
    text-align: center;
  }
  .bonus-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .bonus-ic {
    font-size: 1.05rem;
    line-height: 1;
  }
  .bonus-name {
    color: var(--color-primary);
    font-weight: 600;
  }
</style>
