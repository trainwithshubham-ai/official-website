---
// StructuredData — JSON-LD for the search-first audience. Emits one @graph:
//   • Organization (real Google aggregateRating lives on the DevOps Course only)
//   • Course (+ region Offers priced to match the rendered price)
//   • FAQPage
// Default = the main DevOps course (from site.ts + faq.json). Pass `course` to emit a
// standalone course page's graph instead (name/price/faq from courses.ts). Nothing is
// fabricated (golden rule 4): a course page carries NO aggregateRating, because the
// 4.9/232 Google reviews are the DevOps business rating, not that course's.
import { site } from "../config/site";
import { faq } from "../content/data";
import type { Course } from "../config/courses";

interface Props {
  /** Same description string BaseLayout renders in <meta name="description">. */
  description: string;
  /** When set, emit this course's graph instead of the main DevOps graph. */
  course?: Course;
  /** Catalog/index pages (e.g. /courses): emit ONLY Organization — not the DevOps
   *  Course/Offer/aggregateRating/FAQ graph, which doesn't belong on a catalog URL. */
  collection?: boolean;
}
const { description, course, collection } = Astro.props;

const home = `${site.domain}/`;
const orgId = `${home}#org`;
const toNum = (s: string) => Number(String(s).replace(/[^0-9.]/g, ""));

// One Offer builder for both branches (course page + main DevOps).
const makeOffer = (
  priceCurrency: string,
  price: number,
  url: string,
  validUntil?: string,
) => ({
  "@type": "Offer",
  category: "Paid",
  priceCurrency,
  price,
  ...(validUntil ? { priceValidUntil: validUntil } : {}),
  availability: "https://schema.org/InStock",
  url,
});

const organization = {
  "@type": "Organization",
  "@id": orgId,
  name: site.brand,
  url: home,
  logo: `${site.domain}/logo.png`,
  sameAs: [
    site.social.youtube.url,
    site.social.linkedin.url,
    site.social.instagram.url,
    site.englishSocial.youtube,
    site.englishSocial.instagram,
  ],
};

let graph;

if (collection) {
  // Catalog page — brand identity only; no Course/Offer/rating/FAQ (none of it is
  // shown here, and it would duplicate/misattribute the homepage's Course graph).
  graph = [organization];
} else if (course) {
  // --- Standalone course page ---
  // Advertise the price the page actually renders (the `now` price). No early-bird
  // window means no priceValidUntil — a standing offer with no expiry.
  const pick = (p: { now: string; list: string }) => toNum(p.now);
  // Trailing slash to match BaseLayout's canonical (new URL(pathname) → "/python/").
  const url = `${site.domain}/${course.slug}/`;
  graph = [
    organization,
    {
      "@type": "Course",
      name: course.title,
      description,
      url,
      provider: { "@id": orgId },
      hasCourseInstance: {
        "@type": "CourseInstance",
        courseMode: "online",
        ...(course.batchStartISO ? { startDate: course.batchStartISO } : {}),
        instructor: {
          "@type": "Person",
          name: "Shubham Londhe",
          url: site.social.linkedin.url,
        },
      },
      // Offers only when the course is actually for sale (a coming-soon course has no
      // price yet — emitting a price-less Offer would be invalid / dishonest).
      ...(course.price
        ? {
            offers: [
              makeOffer("INR", pick(course.price.india), `${url}#enroll`),
              makeOffer("USD", pick(course.price.world), `${url}#enroll`),
            ],
          }
        : {}),
    },
    ...(course.faq?.length
      ? [
          {
            "@type": "FAQPage",
            mainEntity: course.faq.map((f) => ({
              "@type": "Question",
              name: f.q,
              acceptedAnswer: { "@type": "Answer", text: f.a },
            })),
          },
        ]
      : []),
  ];
} else {
  // --- Main DevOps course (default) ---
  // Advertise the price the page actually renders (the `now` price). No early-bird
  // window means no priceValidUntil — a standing offer with no expiry.
  const inrPrice = toNum(site.price.india.now);
  const usdPrice = toNum(site.price.world.now);

  // Same token substitution FAQ.astro applies (no literal {classDays}… placeholders).
  const batchStart = new Date(site.batchStartISO).toLocaleDateString("en-IN", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
  const fill = (s: string) =>
    s
      .replaceAll("{classDays}", site.classDays)
      .replaceAll("{classTime}", site.classTime)
      .replaceAll("{batchStart}", batchStart);

  const pricingUrl = `${home}#pricing`;
  graph = [
    organization,
    {
      "@type": "Course",
      name: site.product,
      description,
      url: home,
      provider: { "@id": orgId },
      // Real learner rating (4.9 / 232) — on the Course (the reviewed product), not the
      // Organization, so it's rich-result eligible and not a self-serving org rating.
      aggregateRating: {
        "@type": "AggregateRating",
        ratingValue: site.googleRating,
        reviewCount: site.googleReviewCount,
      },
      hasCourseInstance: {
        "@type": "CourseInstance",
        courseMode: "online",
        startDate: site.batchStartISO,
        instructor: {
          "@type": "Person",
          name: "Shubham Londhe",
          url: site.social.linkedin.url,
        },
      },
      offers: [
        makeOffer("INR", inrPrice, pricingUrl),
        makeOffer("USD", usdPrice, pricingUrl),
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: fill(f.a) },
      })),
    },
  ];
}

const jsonLd = { "@context": "https://schema.org", "@graph": graph };
// Escape "<" so a stray "</script>" or "<" in any answer can't break out of the inline
// script; < is valid JSON and parses back identically.
const json = JSON.stringify(jsonLd).replace(/</g, "\\u003c");
---

<script type="application/ld+json" is:inline set:html={json} />
