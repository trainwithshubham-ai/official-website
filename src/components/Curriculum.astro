---
// Curriculum — the signature pipeline (BRAND.md §2, ARCHITECTURE.md §4.6).
// Each module is a deploy stage on a vertical rail, from `code` to
// `production`. Accordions are native <details>/<summary> — ZERO JavaScript.
// Data mirrors curriculumSchema in content.config.ts.
import Section from "./primitives/Section.astro";
import ToolIcon from "./primitives/ToolIcon.astro";
import Button from "./primitives/Button.astro";
import { curriculum } from "../content/data";
import { site } from "../config/site";

// Subtle live-format cues, authored from the class schedule (golden rule 8 — the
// ops sheet is a reference, never embedded). Keeps the curriculum honest about
// what the batch actually is: live, weekend-friendly, ~3 months, 150+ hours.
const liveMeta = [
  `${site.classDays} · ${site.classTime}`,
  `${site.programLength} program`,
  `${site.liveHours} hours of live class`,
];
---

<Section id="curriculum" eyebrow="curriculum" title="From code to production">
  <p class="mb-5 max-w-2xl text-pretty text-muted">
    Every module is a stage in the pipeline — from your first line of code to
    shipping in production. Expand any stage to see what you'll build.
  </p>

  <ul class="live-meta" role="list" aria-label="Live class format">
    <li class="live-badge">
      <span class="text-primary" aria-hidden="true">❯</span> live cohort
    </li>
    {liveMeta.map((m) => <li>{m}</li>)}
  </ul>

  <ol class="rail-list" role="list">
    {
      curriculum.map((s, i) => (
        <li class="stage">
          <span
            class:list={["dot", i === curriculum.length - 1 && "pulse-dot"]}
            aria-hidden="true"
          />
          <details class="surface-card card" open={i === 0}>
            <summary>
              <span class="grow">
                <span class="stage-label">
                  stage {s.stage} · {s.label}
                </span>
                <h3 class="mt-1">{s.title}</h3>
                <span class="tags">
                  {s.tags.map((t) => (
                    <span class="tag">
                      <ToolIcon name={t} class="text-[0.95rem] text-primary" />
                      {t}
                    </span>
                  ))}
                </span>
              </span>
              <svg
                class="chev"
                viewBox="0 0 20 20"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M5 7.5L10 12.5L15 7.5"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </summary>
            <ul class="bullets" role="list">
              {s.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </details>
        </li>
      ))
    }
  </ol>

  {/* Wayfinding to the exhaustive syllabus on the LMS. Ghost (not the yellow
      Enroll CTA — golden rule 5); data-track fires outbound_click, not a
      checkout event; opens on the LMS host in a new tab so the sales page
      stays alive (golden rule 8 — link out, never embed). */}
  <div class="full-syllabus">
    <Button
      variant="ghost"
      href={site.lms.devopsCurriculum}
      data-track="devops-full-curriculum"
      target="_blank"
    >
      See the full syllabus
      <svg class="ext" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path
          d="M7.5 4.5h8v8M15.5 4.5l-10 10"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      <span class="sr-only">(opens on the LMS in a new tab)</span>
    </Button>
  </div>
</Section>

<style>
  /* Subtle live-format cues (mono pills) under the intro — states the batch is
     live, weekend-friendly, ~3 months, 150+ hours, without a heavy schedule table. */
  .live-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 2.5rem;
    padding: 0;
    list-style: none;
  }
  .live-meta li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    padding: 0.25rem 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
  }
  .live-meta .live-badge {
    color: var(--color-text);
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-line));
  }

  .rail-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .stage {
    position: relative;
    padding-left: 2.5rem;
    padding-bottom: 1.25rem;
  }
  .stage:last-child {
    padding-bottom: 0;
  }

  /* the connecting rail line (code → production) */
  .stage::before {
    content: "";
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-line);
  }
  .stage:first-child::before {
    top: calc(1.4rem + 7px);
  }
  .stage:last-child::before {
    bottom: auto;
    height: calc(1.4rem + 7px);
  }

  /* status node — primary = a real, sequential stage (BRAND §6) */
  .dot {
    position: absolute;
    left: 0;
    top: 1.4rem;
    width: 14px;
    height: 14px;
    border-radius: 9999px;
    background: var(--color-primary);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-primary) 14%, transparent);
  }

  .card {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    transition: border-color 0.15s ease;
  }
  .card:hover {
    border-color: var(--color-primary); /* fallback if color-mix unsupported */
  }
  @supports (color: color-mix(in srgb, red, blue)) {
    .card:hover {
      border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-line));
    }
  }

  summary {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.25rem;
    cursor: pointer;
    list-style: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  /* unmistakable, inset focus ring so it never merges with the card/rail edge */
  summary:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
    border-radius: var(--radius-card);
  }
  .grow {
    flex: 1;
  }

  .stage-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--color-primary);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
  }

  .chev {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--color-muted);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card[open] .chev {
    transform: rotate(180deg);
  }
  .card[open] summary .chev {
    color: var(--color-primary);
  }

  /* Smooth accordion expand/collapse. Modern CSS: animates to/from the
     intrinsic height via interpolate-size. Degrades to an instant snap where
     unsupported, and the global prefers-reduced-motion switch zeroes it out. */
  @media (prefers-reduced-motion: no-preference) {
    @supports (interpolate-size: allow-keywords) {
      .card {
        interpolate-size: allow-keywords;
      }
      .card::details-content {
        block-size: 0;
        overflow: clip;
        opacity: 0;
        transition:
          block-size 0.34s cubic-bezier(0.4, 0, 0.2, 1),
          opacity 0.3s ease,
          content-visibility 0.34s allow-discrete;
      }
      .card[open]::details-content {
        block-size: auto;
        opacity: 1;
      }
    }
  }

  .bullets {
    margin: 0;
    padding: 0 1.25rem 1.4rem 1.25rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .bullets li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--color-text);
  }
  .bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 8px;
    height: 2px;
    background: var(--color-primary);
  }

  /* Full-syllabus wayfinding — sits after the rail, aligned with the stage
     cards (past the 2.5rem rail gutter) so it reads as the roadmap's next step. */
  .full-syllabus {
    margin-top: 2rem;
    padding-left: 2.5rem;
  }
  .ext {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
  }
</style>
