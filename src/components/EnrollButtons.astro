---
// EnrollButtons — the two region-specific Learnyst checkout CTAs. The region
// lives on the button (India flag / globe) so the learner picks their own price
// (we NEVER IP-geo-switch the displayed price — both stay visible; golden rule).
// A tiny timezone guess (BaseLayout, Asia/Kolkata → India, never IP) sets the
// likely region as the solid-yellow PRIMARY and the other as a purple-outline
// secondary — visual weight only (no reorder; stable DOM/focus order). Both
// buttons stay fully visible, clickable and priced (headline shows both). It
// never hides or swaps a price. Checkouts open in a new tab so a wrong click is
// recoverable. Both buttons are `data-enroll`: BaseLayout forwards UTM (+ src),
// preserves ?priceId, and fires enroll_click with the data-region.
import { site } from "../config/site";
import type { CoursePrice, CourseCheckout } from "../config/courses";
import Button from "./primitives/Button.astro";
import FlagIndia from "./primitives/FlagIndia.astro";
import Globe from "./primitives/Globe.astro";

interface Props {
  class?: string;
  /** Show the welcoming geo-pricing note under the buttons (Pricing box only). */
  note?: boolean;
  /** Per-course checkout URLs; defaults to the main DevOps course (site.checkout). */
  checkout?: CourseCheckout;
  /** Per-course prices (for the aria-labels); defaults to site.price. */
  price?: CoursePrice;
  /** SR-label price qualifier appended after the amount (e.g. "launch price").
   *  Defaults to "" — the page carries no early-bird/limited-window framing. */
  priceQualifier?: string;
  /** Course slug forwarded to the enroll_click analytics event (per-course funnel). */
  courseSlug?: string;
}
const {
  class: className = "",
  note = false,
  checkout = site.checkout,
  price = site.price,
  priceQualifier = "",
  courseSlug,
} = Astro.props;
const q = priceQualifier ? ` ${priceQualifier}` : "";
---

<div class:list={["enroll-group", className]} data-enroll-group>
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
    <Button
      href={checkout.india}
      enroll
      variant="ghost"
      data-region="india"
      data-region-btn="india"
      data-course={courseSlug}
      aria-label={`Pay — India pricing, ${price.india.now}${q} (opens in a new tab)`}
      class="region-btn w-full sm:w-auto sm:min-w-[13rem]"
    >
      <FlagIndia width={18} height={12} />
      Pay · India <span class="font-normal opacity-75">·</span> ₹
    </Button>

    <Button
      href={checkout.world}
      enroll
      variant="ghost"
      data-region="world"
      data-region-btn="world"
      data-course={courseSlug}
      aria-label={`Pay — rest-of-world pricing, ${price.world.now}${q} (opens in a new tab)`}
      class="region-btn w-full sm:w-auto sm:min-w-[13rem]"
    >
      <Globe size={18} />
      Pay · Global <span class="font-normal opacity-75">·</span> $
    </Button>
  </div>

  {
    note && (
      <p class="geo-note">
        {/* base shows without JS; CSS swaps to a region variant from the
            html[data-region-guess] flag (set pre-paint in BaseLayout). */}
        <span class="geo-base">
          Pricing is regional — ₹ in India, $ everywhere else. Pick the one for
          where you're paying from; it opens in a new tab.
        </span>
        <span class="geo-india">
          Looks like you're in India 🇮🇳 — the ₹ price is yours. Paying from
          outside India? The $ option works too.
        </span>
        <span class="geo-world">
          Looks like you're outside India 🌐 — the $ price is yours. In India? The
          ₹ option works too.
        </span>
      </p>
    )
  }
</div>

<style>
  /* Region hierarchy — PAINT ONLY, keyed on html[data-region-guess] which
     BaseLayout sets SYNCHRONOUSLY before first paint (no flash, no layout shift,
     no reorder → stable DOM/focus order, WCAG-safe). Buttons render as `ghost`
     (purple-outline secondary); the LIKELY region — the timezone guess, India by
     default when the attr is unset (India-majority; page leads with ₹) — is
     promoted to the solid-yellow PRIMARY CTA. Timezone, never IP (golden rule 6);
     both buttons stay visible + clickable, so this is emphasis, never a swap.
     Mirrors Button.astro's `primary` via the same tokens (--color-cta/-ink/-deep).
     :global because .region-btn is the child <a> and <html> is outside this
     component's scope. */
  :global(html:not([data-region-guess="world"]) .region-btn[data-region-btn="india"]),
  :global(html[data-region-guess="world"] .region-btn[data-region-btn="world"]) {
    background-color: var(--color-cta);
    color: var(--color-ink);
    border-color: transparent;
  }
  :global(html:not([data-region-guess="world"]) .region-btn[data-region-btn="india"]:hover),
  :global(html[data-region-guess="world"] .region-btn[data-region-btn="world"]:hover) {
    background-color: var(--color-cta-deep);
  }
  /* Match the primary CTA's focus ring (yellow), not the ghost's purple. */
  :global(html:not([data-region-guess="world"]) .region-btn[data-region-btn="india"]:focus-visible),
  :global(html[data-region-guess="world"] .region-btn[data-region-btn="world"]:focus-visible) {
    outline-color: var(--color-cta);
  }

  /* Welcoming geo note. All three variants are stacked in ONE grid cell so the
     box always sizes to the tallest variant — swapping which is visible can never
     change the height (zero CLS). We toggle `visibility`, not `display`, to keep
     them all in layout. Keyed on html[data-region-guess]; base shows when the
     region is unknown (no JS). */
  .geo-note {
    margin-top: 0.85rem;
    display: grid;
    text-align: center;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-muted);
  }
  .geo-note > span {
    grid-area: 1 / 1; /* overlap in the same cell */
  }
  .geo-india,
  .geo-world {
    visibility: hidden;
  }
  :global(html[data-region-guess="india"]) .geo-base,
  :global(html[data-region-guess="world"]) .geo-base {
    visibility: hidden;
  }
  :global(html[data-region-guess="india"]) .geo-india {
    visibility: visible;
  }
  :global(html[data-region-guess="world"]) .geo-world {
    visibility: visible;
  }
</style>
