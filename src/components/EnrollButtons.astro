---
// EnrollButtons — the two region-specific Learnyst checkout CTAs. The region
// lives on the button (India flag / globe) so the learner picks their own price
// (we NEVER IP-geo-switch the displayed price — both stay visible; golden rule).
// A tiny timezone guess (BaseLayout, Asia/Kolkata → India, never IP) sets the
// likely region as the solid-yellow PRIMARY and the other as a purple-outline
// secondary — visual weight only (no reorder; stable DOM/focus order). Both
// buttons stay fully visible, clickable and priced (headline shows both). It
// never hides or swaps a price. Checkouts open in a new tab so a wrong click is
// recoverable. Both buttons are `data-enroll`: BaseLayout forwards UTM (+ src),
// preserves ?priceId, and fires enroll_click with the data-region.
import { site } from "../config/site";
import Button from "./primitives/Button.astro";
import FlagIndia from "./primitives/FlagIndia.astro";
import Globe from "./primitives/Globe.astro";

interface Props {
  class?: string;
  /** Show the welcoming geo-pricing note under the buttons (Pricing box only). */
  note?: boolean;
}
const { class: className = "", note = false } = Astro.props;
---

<div class:list={["enroll-group", className]} data-enroll-group>
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
    <Button
      href={site.checkout.india}
      enroll
      variant="ghost"
      data-region="india"
      data-region-btn="india"
      aria-label={`Pay — India pricing, ${site.price.india.early} early bird (opens in a new tab)`}
      class="region-btn w-full sm:w-auto sm:min-w-[13rem]"
    >
      <FlagIndia width={18} height={12} />
      Pay · India <span class="font-normal opacity-75">·</span> ₹
    </Button>

    <Button
      href={site.checkout.world}
      enroll
      variant="ghost"
      data-region="world"
      data-region-btn="world"
      aria-label={`Pay — rest-of-world pricing, ${site.price.world.early} early bird (opens in a new tab)`}
      class="region-btn w-full sm:w-auto sm:min-w-[13rem]"
    >
      <Globe size={18} />
      Pay · Global <span class="font-normal opacity-75">·</span> $
    </Button>
  </div>

  {
    note && (
      <p class="geo-note">
        {/* base shows without JS; CSS swaps to a region variant once the
            timezone guess sets data-region-guess on the group wrapper. */}
        <span class="geo-base">
          Pricing is regional — ₹ in India, $ everywhere else. Pick the one for
          where you're paying from; it opens in a new tab.
        </span>
        <span class="geo-india">
          Looks like you're in India 🇮🇳 — the ₹ price is yours. Paying from
          outside India? The $ option works too.
        </span>
        <span class="geo-world">
          Looks like you're outside India 🌐 — the $ price is yours. In India? The
          ₹ option works too.
        </span>
      </p>
    )
  }
</div>

<style>
  /* Region hierarchy — PAINT ONLY (no layout shift, no reorder, both buttons stay
     clickable and in stable DOM/focus order). Buttons render as `ghost`
     (purple-outline secondary); the LIKELY region — the timezone guess, India by
     default when there's no guess/no JS (India-majority audience; the page leads
     with the India price) — is promoted to the solid-yellow PRIMARY CTA. The
     guess is timezone-based, never IP (golden rule 6); the headline shows both
     prices regardless, so this is emphasis, never a price swap.
     NB: mirrors Button.astro's `primary` variant via the same tokens
     (--color-cta / --color-ink / --color-cta-deep) — keep in sync if that
     variant changes structurally. :global because .region-btn is the child <a>.
     Deliberately NO CSS `order`: reordering focusable buttons would break
     keyboard/SR focus order (WCAG 2.4.3) — the yellow fill carries the emphasis. */
  :global(
      .enroll-group:not([data-region-guess="world"])
        .region-btn[data-region-btn="india"]
    ),
  :global(
      .enroll-group[data-region-guess="world"]
        .region-btn[data-region-btn="world"]
    ) {
    background-color: var(--color-cta);
    color: var(--color-ink);
    border-color: transparent;
  }
  :global(
      .enroll-group:not([data-region-guess="world"])
        .region-btn[data-region-btn="india"]:hover
    ),
  :global(
      .enroll-group[data-region-guess="world"]
        .region-btn[data-region-btn="world"]:hover
    ) {
    background-color: var(--color-cta-deep);
  }
  /* Match the primary CTA's focus ring (yellow), not the ghost's purple, so the
     promoted button's focus affordance matches its look. */
  :global(
      .enroll-group:not([data-region-guess="world"])
        .region-btn[data-region-btn="india"]:focus-visible
    ),
  :global(
      .enroll-group[data-region-guess="world"]
        .region-btn[data-region-btn="world"]:focus-visible
    ) {
    outline-color: var(--color-cta);
  }

  /* Welcoming geo note. All three variants are stacked in ONE grid cell so the
     box always sizes to the tallest variant — swapping which one is visible can
     never change the height (zero CLS, even at 380px where they differ in line
     count). We toggle `visibility`, not `display`, to keep them all in layout. */
  .geo-note {
    margin-top: 0.85rem;
    display: grid;
    text-align: center;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-muted);
  }
  .geo-note > span {
    grid-area: 1 / 1; /* overlap in the same cell */
  }
  /* Default (no JS / unknown region): base visible, others hidden-but-present. */
  .geo-india,
  .geo-world {
    visibility: hidden;
  }
  .enroll-group[data-region-guess="india"] .geo-base,
  .enroll-group[data-region-guess="world"] .geo-base {
    visibility: hidden;
  }
  .enroll-group[data-region-guess="india"] .geo-india {
    visibility: visible;
  }
  .enroll-group[data-region-guess="world"] .geo-world {
    visibility: visible;
  }
</style>
