---
// Credential — the verifiable badge learners earn (honest framing: this is the
// TrainWithShubham DevOps Engineer (Associate) credential, not an external/vendor
// certification — golden rule 4, no overclaiming). Badge served locally.
import Eyebrow from "./primitives/Eyebrow.astro";
import { site } from "../config/site";

// Link the badge to its public verification page when the URL is set.
const canVerify =
  !!site.credentialUrl && !site.credentialUrl.startsWith("TODO");

const points = [
  "Add it to your LinkedIn profile and résumé",
  "A verifiable, shareable digital badge",
  "Backed by the projects and capstone you ship",
];
---

<section id="credential" class="reveal py-[clamp(4rem,9vw,7rem)]">
  <div
    class="mx-auto w-full max-w-[var(--container-content)] px-6"
  >
    <div
      class="surface-card grad-border grid items-center gap-8 rounded-[var(--radius-card)] p-8 sm:p-10 md:grid-cols-[auto_1fr] md:gap-12"
    >
      {
        canVerify ? (
          <a
            href={site.credentialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group mx-auto flex flex-col items-center gap-2.5 transition-transform motion-safe:hover:-translate-y-0.5"
          >
            <img
              src="/credential-devops-engineer.png"
              alt=""
              width="192"
              height="192"
              class="size-40 md:size-48"
              loading="lazy"
              decoding="async"
            />
            <span class="font-mono text-xs text-teal group-hover:underline">
              verify this credential <span aria-hidden="true">↗</span>
              <span class="sr-only">(opens in new tab)</span>
            </span>
          </a>
        ) : (
          <img
            src="/credential-devops-engineer.png"
            alt="TrainWithShubham DevOps Engineer (Associate) credential badge"
            width="192"
            height="192"
            class="mx-auto size-40 md:size-48"
            loading="lazy"
            decoding="async"
          />
        )
      }

      <div class="flex flex-col gap-4">
        <Eyebrow text="credential" />
        <h2 class="text-balance">Finish, and earn a credential to show for it</h2>
        <p class="max-w-xl text-pretty text-muted">
          Complete the cohort and earn the
          <span class="text-text"
            >TrainWithShubham DevOps Engineer (Associate)</span
          > credential — proof you can build and ship real systems, not just watch
          videos.
        </p>
        <ul class="flex flex-col gap-3" role="list">
          {
            points.map((p) => (
              <li class="flex items-start gap-3">
                <svg
                  class="mt-0.5 size-5 shrink-0 text-teal"
                  viewBox="0 0 20 20"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M4 10.5l3.5 3.5L16 6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span class="text-text">{p}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
