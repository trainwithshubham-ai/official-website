---
// Countdown — the ONLY interactive island (ARCHITECTURE.md §5).
// Framed as the deploy window counting down to the batch start (BRAND.md §2, §6).
//
// One component, several mounts (nav / hero / pricing). The <script> below is
// emitted once by Astro no matter how many times the component renders; it drives
// every [data-countdown] instance on the page.
//
// Honest scarcity: on expiry it does NOT reset or vanish — it flips to a calm
// "batch is live · enrolment open" state via [data-expired] (CSS swap, no layout
// shift, works even if JS is slow).
//
// Two modes (one shared script):
//   • fixed  (default) — counts to site.batchStartISO, the real cohort start.
//   • daily  — counts to TONIGHT'S midnight IST for the repeatable daily bonus,
//     then genuinely rolls to the next day. A real end-of-day deadline, never a
//     fake per-visit 24h reset (golden rule 6 stays intact).
import { site } from "../config/site";

interface Props {
  variant?: "full" | "chip" | "bonus";
  /** "daily" rolls to the next IST midnight (bonus); "fixed" is the batch-start date. */
  mode?: "fixed" | "daily";
  /** Expose the deadline to screen readers. Set on exactly ONE mount per page
   *  so the same deadline isn't announced multiple times. */
  announceDeadline?: boolean;
  class?: string;
}
const {
  variant = "full",
  mode = "fixed",
  announceDeadline = false,
  class: className = "",
} = Astro.props;

// Static, screen-reader-friendly deadline (the ticking digits are aria-hidden).
const deadlineLabel = new Date(site.batchStartISO).toLocaleString("en-IN", {
  day: "numeric",
  month: "long",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  timeZone: "Asia/Kolkata",
});

const units = [
  { key: "d", label: "days" },
  { key: "h", label: "hrs" },
  { key: "m", label: "min" },
  { key: "s", label: "sec" },
];
---

<div
  class:list={["countdown", `countdown--${variant}`, className]}
  data-countdown
  data-mode={mode}
  data-deadline={mode === "fixed" ? site.batchStartISO : undefined}
  data-expired="false"
>
  {
    variant === "bonus" ? (
      /* slim inline HH:MM:SS for the daily bonus (digits aria-hidden) */
      <span class="cd-bonus font-mono" aria-hidden="true">
        <span data-unit="h">--</span>:<span data-unit="m">--</span>:
        <span data-unit="s">--</span>
      </span>
    ) : (
      <Fragment>
        {/* live ticker (visual only) */}
        <div class="cd-live" aria-hidden="true">
          {variant === "full" && (
            <p class="font-mono text-[length:var(--text-eyebrow)] lowercase tracking-[0.08em] text-signal">
              ❯ batch starts in
            </p>
          )}
          <div class="cd-units">
            {units.map((u) => (
              <span class="cd-unit">
                <span class="cd-num font-mono" data-unit={u.key}>
                  --
                </span>
                <span class="cd-lbl font-mono">{u.label}</span>
              </span>
            ))}
          </div>
        </div>

        {/* expired state (revealed by CSS when [data-expired="true"]) */}
        <p class="cd-ended font-mono text-[length:var(--text-eyebrow)] text-muted">
          <span class="text-signal" aria-hidden="true">
            ●
          </span>{" "}
          batch is live · enrolment open
        </p>

        {/* Accessible deadline — exposed on exactly ONE mount (announceDeadline)
            so screen readers don't hear the same deadline repeated. */}
        {announceDeadline && (
          <span class="sr-only">The batch starts {deadlineLabel} IST.</span>
        )}
      </Fragment>
    )
  }
</div>

<style>
  .countdown {
    display: inline-flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .cd-units {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }
  .cd-unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 3.25rem;
    padding: 0.5rem 0.5rem 0.4rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 10px;
  }
  .cd-num {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
  }
  .cd-lbl {
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  /* compact chip for the nav */
  .countdown--chip .cd-units {
    gap: 0.25rem;
  }
  .countdown--chip .cd-unit {
    flex-direction: row;
    align-items: baseline;
    gap: 0.15rem;
    min-width: 0;
    padding: 0.2rem 0.4rem;
    background: transparent;
    border: 0;
  }
  .countdown--chip .cd-num {
    font-size: 0.95rem;
    color: var(--color-signal);
  }
  .countdown--chip .cd-lbl {
    font-size: 0.6rem;
  }

  /* slim inline timer for the daily bonus */
  .cd-bonus {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-signal);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  /* expiry swap — no layout shift, CSS-driven */
  .cd-ended {
    display: none;
  }
  .countdown[data-expired="true"] .cd-live {
    display: none;
  }
  .countdown[data-expired="true"] .cd-ended {
    display: block;
  }
</style>

<script>
  // Drives every countdown on the page from ONE timer. No framework.
  // Per node: mode="fixed" → counts to its data-deadline (the batch start), then
  // flips to the calm expired state. mode="daily" → counts to the next midnight
  // IST and ROLLS to the following day (the repeatable bonus deadline); it never
  // expires. IST is a fixed +5:30 offset (no DST).
  const nodes = Array.from(
    document.querySelectorAll<HTMLElement>("[data-countdown]"),
  );
  if (nodes.length) {
    const pad = (n: number) => String(n).padStart(2, "0");
    const IST = 19_800_000; // +5:30 in ms
    const DAY = 86_400_000;
    const nextISTMidnight = () =>
      (Math.floor((Date.now() + IST) / DAY) + 1) * DAY - IST;

    type St = {
      n: HTMLElement;
      daily: boolean;
      target: number;
      done: boolean;
    };
    const states: St[] = nodes.map((n) => {
      const daily = n.dataset.mode === "daily";
      return {
        n,
        daily,
        target: daily
          ? nextISTMidnight()
          : new Date(n.dataset.deadline || "").getTime(),
        done: false,
      };
    });

    const renderNode = (st: St) => {
      if (st.done) return;
      let diff = st.target - Date.now();
      if (diff <= 0) {
        if (st.daily) {
          st.target = nextISTMidnight(); // roll to the next day — real deadline
          diff = st.target - Date.now();
        } else {
          st.n.dataset.expired = "true";
          st.done = true;
          return;
        }
      }
      const s = Math.floor(diff / 1000);
      const v = {
        d: Math.floor(s / 86400),
        h: Math.floor((s % 86400) / 3600),
        m: Math.floor((s % 3600) / 60),
        s: s % 60,
      };
      for (const k of ["d", "h", "m", "s"] as const) {
        const el = st.n.querySelector<HTMLElement>(`[data-unit="${k}"]`);
        if (el) el.textContent = pad(v[k]);
      }
    };

    states.forEach(renderNode);
    const id = setInterval(() => {
      states.forEach(renderNode);
      if (states.every((st) => st.done)) clearInterval(id); // only fixed nodes "finish"
    }, 1000);
  }
</script>
