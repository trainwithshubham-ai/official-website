---
// Outcomes — capability cards (ARCHITECTURE.md §4.5). Lead with what the learner
// will be able to DO. Data: outcomes.json.
import Section from "./primitives/Section.astro";
import { outcomes } from "../content/data";
---

<Section
  id="outcomes"
  eyebrow="outcomes"
  title="What you'll be able to do"
>
  <ul class="grid gap-5 sm:grid-cols-2" role="list">
    {
      outcomes.map((o) => (
        <li class="surface-card rounded-[var(--radius-card)] border border-line bg-surface p-6">
          <h3 class="text-text">{o.title}</h3>
          <p class="mt-2 text-pretty text-muted">{o.body}</p>
        </li>
      ))
    }
  </ul>
</Section>
